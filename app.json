{
  "expo": {
    "name": "Chibi Sumo Stable",
    "slug": "chibi-sumo-stable",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff8f0"
    },
    "scheme": "chibisumo",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "build": {
        "serviceWorker": true
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
